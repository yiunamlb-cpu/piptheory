# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real keys.

# --- LLM gateway ---
# OpenRouter routes to Claude / DeepSeek / GPT / Llama with one key.
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model selection per tier (override via agent config if needed)
# Single-model start: same model for both tiers. Differentiate later when you have
# calibration data on which agents need frontier reasoning vs. cheap-tier sufficiency.
MODEL_CHEAP=deepseek/deepseek-v4-pro
MODEL_FRONTIER=deepseek/deepseek-v4-pro
# Recommended Phase B+ frontier swap: anthropic/claude-sonnet-4.6 for Judge + PM

# --- Macro data ---
# FRED — free, get key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- FX / market data ---
# OANDA practice account (free) at https://oanda.com/account/signup
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice

# --- Optional / Phase B+ ---
# Langfuse self-hosted observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Letta self-hosted memory
LETTA_HOST=http://localhost:8283

# --- Cost guardrails ---
# Hard daily spend cap (USD) across all agents. Pipeline aborts if exceeded.
DAILY_BUDGET_USD=5

# --- Analytics & Ads ---
# Google Analytics 4 measurement ID (get from analytics.google.com)
GA_MEASUREMENT_ID=G-XXXXXXXXXX
