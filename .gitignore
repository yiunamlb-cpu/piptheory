.cache/
data/cache/
data/raw/
*.parquet
*.feather
*.h5

# --- Runtime state (cost tracking, agent memory snapshots, etc.) ---
state/

# --- Bias cards (agent outputs revealing current positioning thinking) ---
bias_cards/

