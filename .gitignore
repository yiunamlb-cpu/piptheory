journal/
trades/
positions/
fills/

# --- Backtest outputs ---
backtest_results/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Model artifacts ---
models/checkpoints/
*.pkl
*.joblib

# --- Agent traces (Langfuse exports, debug dumps) ---
traces/

# --- MT5 compiled artifacts (commit .mq5 source, ignore compiled) ---
*.ex5
*.ex4

